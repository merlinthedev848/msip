<?xml version="1.0"?>
<document type="freeswitch/xml">
  <section name="configuration" description="Various Configuration">
    <configuration name="switch.conf" description="Core Configuration">
      <settings>
        <param name="rtp-start-port" value="16384"/>
        <param name="rtp-end-port" value="32768"/>
        <!-- Enable media bypass / pass-through for low CPU usage -->
        <param name="inbound-bypass-media" value="true"/>
      </settings>
    </configuration>
    
    <configuration name="json_cdr.conf" description="JSON CDR">
      <settings>
        <!-- POST CDRs directly to the Go Backend -->
        <param name="url" value="http://pbx_backend:8081/api/cdr"/>
        <param name="retries" value="3"/>
        <param name="delay" value="120"/>
        <param name="log-b-leg" value="false"/>
      </settings>
    </configuration>
    
    <configuration name="modules.conf" description="Modules">
      <modules>
        <!-- Load mod_xml_curl to fetch configs from Go backend -->
        <load module="mod_xml_curl"/>
        
        <!-- Standard core modules -->
        <load module="mod_sofia"/>
        <load module="mod_dialplan_xml"/>
        <load module="mod_commands"/>
        <load module="mod_dptools"/>
        
        <!-- Enterprise Features -->
        <load module="mod_json_cdr"/>
        <load module="mod_voicemail"/>
        <load module="mod_flite"/>
        <load module="mod_conference"/>
        <load module="mod_callcenter"/>
      </modules>
    </configuration>
    
    <!-- Load cURL configuration -->
    <X-PRE-PROCESS cmd="include" data="xml_curl.conf.xml"/>
  </section>
  <section name="dialplan" description="Regex/XML Dialplan">
    <context name="default">
      <extension name="echo_test">
        <condition field="destination_number" expression="^9999$">
          <action application="answer"/>
          <action application="echo"/>
        </condition>
      </extension>
    </context>
  </section>
</document>
